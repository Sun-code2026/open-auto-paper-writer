OPENAI_API_KEY=sk-your-server-side-openai-key
OPENAI_MODEL=chat-latest
APP_SESSION_SECRET=replace-with-a-long-random-string
APP_ORIGIN=http://127.0.0.1:5173
PORT=8787

# Set true in production so only active subscribers can generate manuscripts.
REQUIRE_ACTIVE_SUBSCRIPTION=false

# Simple allow-list for early paid users or manual subscriptions.
ALLOWED_SUBSCRIBERS=researcher@example.com

# Optional Stripe subscription checkout.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
PUBLIC_APP_URL=http://127.0.0.1:5173
